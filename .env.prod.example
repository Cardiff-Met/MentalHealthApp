# =============================================================================
# Production environment template — copy to `.env.prod` and fill in real values.
# DO NOT commit `.env.prod` to git. Keep this template (`.env.prod.example`)
# committed so the variables are documented.
# =============================================================================

# Public origin of the front-end (used for the CORS allow-list).
CLIENT_URL=https://mindspace.example.com

# Database credentials. Use a strong, unique DB_ROOT_PASSWORD and DB_PASSWORD.
DB_ROOT_PASSWORD=replace-me-with-a-strong-root-password
DB_NAME=mental_health_app
DB_USER=mindspace_app
DB_PASSWORD=replace-me-with-a-strong-app-password

# JWT secrets. Both MUST be at least 32 characters.
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-64-hex-chars-minimum
REFRESH_SECRET=replace-me-64-hex-chars-minimum
