# Normalise line endings to LF in the repo; Git will convert to CRLF on
# Windows checkouts automatically — stops "modified" noise on Windows machines.
* text=auto eol=lf

# Binaries — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
